<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/rootLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/margin_medium">

        <!-- HEADER: App Title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingBottom="@dimen/margin_large">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👋 Senior Launcher"
                android:textSize="@dimen/text_heading_size"
                android:textStyle="bold"
                android:textColor="@color/text_primary_dark" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/quick_contacts_hint"
                android:textSize="@dimen/text_small_size"
                android:textColor="@color/text_secondary_dark"
                android:layout_marginTop="@dimen/margin_tiny" />
        </LinearLayout>

        <!-- SECTION 1: QUICK FAMILY CONTACTS (2x2 Grid) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_horizontal">

            <!-- Contact 1: Son -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="@dimen/contact_image_size"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingEnd="@dimen/margin_small"
                android:paddingRight="@dimen/margin_small">

                <ImageButton
                    android:id="@+id/btnCall1"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:background="@drawable/circle_button_son"
                    android:contentDescription="@string/contact_1"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_family_son"
                    android:padding="12dp" />

                <TextView
                    android:id="@+id/lblCall1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="👨 Son"
                    android:gravity="center"
                    android:textSize="@dimen/text_label_size"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary_dark"
                    android:layout_marginTop="@dimen/margin_small" />
            </LinearLayout>

            <!-- Contact 2: Daughter -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="@dimen/contact_image_size"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingStart="@dimen/margin_small"
                android:paddingLeft="@dimen/margin_small">

                <ImageButton
                    android:id="@+id/btnCall2"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:background="@drawable/circle_button_daughter"
                    android:contentDescription="@string/contact_2"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_family_daughter"
                    android:padding="12dp" />

                <TextView
                    android:id="@+id/lblCall2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="👩 Daughter"
                    android:gravity="center"
                    android:textSize="@dimen/text_label_size"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary_dark"
                    android:layout_marginTop="@dimen/margin_small" />
            </LinearLayout>
        </LinearLayout>

        <!-- SECTION 1 (cont): QUICK FAMILY CONTACTS (2x2 Grid - Row 2) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_horizontal"
            android:layout_marginTop="@dimen/margin_large">

            <!-- Contact 3: Home -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="@dimen/contact_image_size"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingEnd="@dimen/margin_small"
                android:paddingRight="@dimen/margin_small">

                <ImageButton
                    android:id="@+id/btnCall3"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:background="@drawable/circle_button_home"
                    android:contentDescription="@string/contact_3"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_family_home"
                    android:padding="12dp" />

                <TextView
                    android:id="@+id/lblCall3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🏠 Home"
                    android:gravity="center"
                    android:textSize="@dimen/text_label_size"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary_dark"
                    android:layout_marginTop="@dimen/margin_small" />
            </LinearLayout>

            <!-- Contact 4: Help -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="@dimen/contact_image_size"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingStart="@dimen/margin_small"
                android:paddingLeft="@dimen/margin_small">

                <ImageButton
                    android:id="@+id/btnCall4"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:background="@drawable/circle_button_help"
                    android:contentDescription="@string/contact_4"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_family_help"
                    android:padding="12dp" />

                <TextView
                    android:id="@+id/lblCall4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🆘 Help"
                    android:gravity="center"
                    android:textSize="@dimen/text_label_size"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary_dark"
                    android:layout_marginTop="@dimen/margin_small" />
            </LinearLayout>
        </LinearLayout>

        <!-- SECTION 2: VOICE COMMAND (Large, Prominent) -->
        <Button
            android:id="@+id/btnVoice"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_min_height"
            android:layout_marginTop="@dimen/margin_large"
            android:text="@string/voice_button"
            android:textSize="@dimen/button_text_size"
            android:textStyle="bold"
            android:background="@drawable/button_voice"
            android:textColor="@color/text_primary_dark" />

        <!-- SECTION 3: COMMON ACTIONS (Row 1) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/margin_large"
            android:gravity="center">

            <Button
                android:id="@+id/btnContactsSection"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_min_height"
                android:layout_weight="1"
                android:text="@string/section_contacts"
                android:textSize="@dimen/button_text_size"
                android:textStyle="bold"
                android:background="@drawable/button_contacts"
                android:textColor="@color/text_primary_dark"
                android:layout_marginEnd="@dimen/margin_small"
                android:layout_marginRight="@dimen/margin_small" />

            <Button
                android:id="@+id/btnGallerySection"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_min_height"
                android:layout_weight="1"
                android:text="@string/section_gallery"
                android:textSize="@dimen/button_text_size"
                android:textStyle="bold"
                android:background="@drawable/button_gallery"
                android:textColor="@color/text_primary_dark"
                android:layout_marginStart="@dimen/margin_small"
                android:layout_marginLeft="@dimen/margin_small"
                android:layout_marginEnd="@dimen/margin_small"
                android:layout_marginRight="@dimen/margin_small" />

            <Button
                android:id="@+id/btnYoutubeSection"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_min_height"
                android:layout_weight="1"
                android:text="@string/section_youtube"
                android:textSize="@dimen/button_text_size"
                android:textStyle="bold"
                android:background="@drawable/button_youtube"
                android:textColor="@color/text_primary_dark"
                android:layout_marginStart="@dimen/margin_small"
                android:layout_marginLeft="@dimen/margin_small" />
        </LinearLayout>

        <!-- SECTION 3: COMMON ACTIONS (Row 2) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/margin_small"
            android:gravity="center">

            <Button
                android:id="@+id/btnWhatsapp"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_min_height"
                android:layout_weight="1"
                android:text="@string/section_whatsapp"
                android:textSize="@dimen/button_text_size"
                android:textStyle="bold"
                android:background="@drawable/button_whatsapp"
                android:textColor="@color/text_primary_dark"
                android:layout_marginEnd="@dimen/margin_small"
                android:layout_marginRight="@dimen/margin_small" />

            <Button
                android:id="@+id/btnFlashlight"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_min_height"
                android:layout_weight="1"
                android:text="@string/section_flashlight"
                android:textSize="@dimen/button_text_size"
                android:textStyle="bold"
                android:background="@drawable/button_flashlight"
                android:textColor="@color/text_primary_dark"
                android:layout_marginStart="@dimen/margin_small"
                android:layout_marginLeft="@dimen/margin_small"
                android:layout_marginEnd="@dimen/margin_small"
                android:layout_marginRight="@dimen/margin_small" />

            <Button
                android:id="@+id/btnSpeakTime"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_min_height"
                android:layout_weight="1"
                android:text="@string/section_speak_time"
                android:textSize="@dimen/button_text_size"
                android:textStyle="bold"
                android:background="@drawable/button_time"
                android:textColor="@color/text_primary_dark"
                android:layout_marginStart="@dimen/margin_small"
                android:layout_marginLeft="@dimen/margin_small" />
        </LinearLayout>

        <!-- SECTION 3: COMMON ACTIONS (Row 3) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/margin_small"
            android:gravity="center">

            <Button
                android:id="@+id/btnVolumeDown"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_min_height"
                android:layout_weight="1"
                android:text="@string/volume_down"
                android:textSize="@dimen/button_text_size"
                android:textStyle="bold"
                android:background="@drawable/button_volume_down"
                android:textColor="@color/text_primary_dark"
                android:layout_marginEnd="@dimen/margin_small"
                android:layout_marginRight="@dimen/margin_small" />

            <Button
                android:id="@+id/btnVolumeUp"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_min_height"
                android:layout_weight="1"
                android:text="@string/volume_up"
                android:textSize="@dimen/button_text_size"
                android:textStyle="bold"
                android:background="@drawable/button_volume_up"
                android:textColor="@color/text_primary_dark"
                android:layout_marginStart="@dimen/margin_small"
                android:layout_marginLeft="@dimen/margin_small"
                android:layout_marginEnd="@dimen/margin_small"
                android:layout_marginRight="@dimen/margin_small" />

            <Button
                android:id="@+id/btnAiAssistant"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_min_height"
                android:layout_weight="1"
                android:text="@string/section_ai"
                android:textSize="@dimen/button_text_size"
                android:textStyle="bold"
                android:background="@drawable/button_ai"
                android:textColor="@color/text_primary_dark"
                android:layout_marginStart="@dimen/margin_small"
                android:layout_marginLeft="@dimen/margin_small" />
        </LinearLayout>

        <!-- SECTION 4: SETTINGS (Settings button at bottom) -->
        <Button
            android:id="@+id/btnCaretakerConfig"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_min_height"
            android:layout_marginTop="@dimen/margin_large"
            android:layout_marginBottom="@dimen/margin_large"
            android:text="@string/section_config"
            android:textSize="@dimen/button_text_size"
            android:textStyle="bold"
            android:background="@drawable/button_settings"
            android:textColor="@color/text_primary_dark" />

        <!-- STATUS MESSAGES -->
        <TextView
            android:id="@+id/txtRecognized"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_medium"
            android:layout_marginBottom="@dimen/margin_small"
            android:gravity="center"
            android:text="@string/recognized_default"
            android:textSize="@dimen/text_body_size"
            android:textColor="@color/text_primary_dark"
            android:textStyle="italic" />

        <TextView
            android:id="@+id/txtPluginInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textSize="@dimen/text_small_size"
            android:textColor="@color/text_secondary_dark" />
    </LinearLayout>
</ScrollView>
